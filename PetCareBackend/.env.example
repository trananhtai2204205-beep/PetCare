# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=petcare_db
DB_USER=root
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=petcare_jwt_secret_key_2024_very_long_string
JWT_REFRESH_SECRET=petcare_refresh_secret_key_2024_another_long_string
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
